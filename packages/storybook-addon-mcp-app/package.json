{
  "name": "@mkl-oss/storybook-addon-mcp-app",
  "version": "0.1.0",
  "description": "Storybook addon for mocking MCP App React integrations in local stories.",
  "author": "MKL Avocat",
  "license": "ISC",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mkl-tech/mkl-oss.git",
    "directory": "packages/storybook-addon-mcp-app"
  },
  "homepage": "https://github.com/mkl-tech/mkl-oss/tree/main/packages/storybook-addon-mcp-app",
  "bugs": {
    "url": "https://github.com/mkl-tech/mkl-oss/issues"
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "preset.js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./manager": {
      "types": "./dist/manager.d.ts",
      "default": "./dist/manager.js"
    },
    "./preview": {
      "types": "./dist/preview.d.ts",
      "default": "./dist/preview.js"
    },
    "./runtime": {
      "types": "./dist/runtime.d.ts",
      "default": "./dist/runtime.js"
    },
    "./package.json": "./package.json"
  },
  "storybook": {
    "displayName": "MCP App Mock",
    "supportedFrameworks": [
      "react"
    ]
  },
  "keywords": [
    "storybook-addon",
    "debug",
    "storybook",
    "mcp",
    "model-context-protocol",
    "react",
    "mock"
  ],
  "bundler": {
    "managerEntries": [
      "./src/manager.tsx"
    ],
    "previewEntries": [
      "./src/preview.tsx"
    ]
  },
  "peerDependencies": {
    "@modelcontextprotocol/ext-apps": "^1.3.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^10.0.7"
  },
  "devDependencies": {
    "@modelcontextprotocol/ext-apps": "1.3.1",
    "@storybook/react": "10.0.7",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "storybook": "10.0.7",
    "typescript": "catalog:"
  }
,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "validate": "pnpm lint && pnpm build"
  }
}
